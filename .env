# OpenAI兼容的API配置 (用于 REASONER_MODEL 和 PERCEIVER_MODEL)
OPENAI_API_KEY=sk-your_actual_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Verifier模型配置 (用于 VERIFIER_MODEL)
VERIFIER_MODEL_API_KEY=your_actual_verifier_api_key_here
VERIFIER_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# USE_ARK_FOR_VERIFIER: true=使用火山引擎Ark客户端, false=使用OpenAI兼容客户端
USE_ARK_FOR_VERIFIER=true


# 模型名称配置
REASONER_MODEL=gpt-5-mini
PERCEIVER_MODEL=gemini-2.5-flash
VERIFIER_MODEL=doubao-seed-1-6-thinking-250715
